{
  "openapi": "3.0.1",
  "info": {
    "title": "Demo API (模板占位)",
    "version": "0.0.1",
    "description": "本文件是模板项目的 OpenAPI 占位 demo, 演示 docs/prds/_template.md 中 user-list 示例所引用的接口形状。下游项目接入时, 用后端导出的真实 OpenAPI 完整替换本文件。"
  },
  "servers": [
    { "url": "https://api.example.com", "description": "demo server" }
  ],
  "tags": [
    { "name": "User", "description": "用户管理 — 模板示例" }
  ],
  "paths": {
    "/api/users/search": {
      "get": {
        "tags": ["User"],
        "operationId": "searchUsers",
        "summary": "按筛选条件搜索用户",
        "parameters": [
          { "name": "phone", "in": "query", "schema": { "type": "string" }, "description": "手机号 (模糊匹配)" },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["enabled", "disabled"] }, "description": "状态筛选" },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/users/{id}": {
      "get": {
        "tags": ["User"],
        "operationId": "getUserById",
        "summary": "按 id 查询用户详情",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          }
        }
      }
    },
    "/api/users/export": {
      "post": {
        "tags": ["User"],
        "operationId": "exportUsers",
        "summary": "导出符合筛选条件的用户为 Excel",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phone": { "type": "string" },
                  "status": { "type": "string", "enum": ["enabled", "disabled"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Excel 文件流",
            "content": {
              "application/octet-stream": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "required": ["id", "phone", "status"],
        "properties": {
          "id": { "type": "string", "description": "用户唯一 id" },
          "phone": { "type": "string", "description": "11 位手机号" },
          "nickname": { "type": "string", "description": "昵称" },
          "status": { "type": "string", "enum": ["enabled", "disabled"], "description": "账号状态" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "UserListResponse": {
        "type": "object",
        "required": ["list", "total"],
        "properties": {
          "list": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/User" }
          },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "pageSize": { "type": "integer" }
        }
      }
    }
  }
}
